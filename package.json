{
  "name": "shoe-and-slipper-store",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node --experimental-sqlite server/src/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node --experimental-sqlite server/src/index.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "eslint": "^9.0.0",
    "express": "^5.1.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {}
}
